<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <%= render FlatPack::PageNav::Component.new(
    anchor_url: notifications_path
  ) %>

  <%= render FlatPack::PageTitle::Component.new(
    title: "#{@digest.notification_type.humanize} digest",
    subtitle: "#{@digest.cadence.humanize} · #{@digest.period_starts_at.to_date} to #{(@digest.period_ends_at.to_date - 1)}",
    variant: :h1
  ) %>

  <div class="grid gap-3 sm:grid-cols-3">
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.body do %>
        <p class="text-xs text-(--surface-muted-content-color)">Events</p>
        <p class="mt-1 text-lg font-semibold"><%= @digest.items.count %></p>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.body do %>
        <p class="text-xs text-(--surface-muted-content-color)">Status</p>
        <p class="mt-1 text-lg font-semibold"><%= @digest.status.humanize %></p>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.body do %>
        <p class="text-xs text-(--surface-muted-content-color)">Scope</p>
        <p class="mt-1 truncate text-lg font-semibold"><%= @digest.root_recording ? "Current workspace" : "All workspaces" %></p>
      <% end %>
    <% end %>
  </div>

  <% if @notifications.any? %>
    <%= render FlatPack::List::Component.new(spacing: :comfortable, divider: true) do %>
      <div id="digest-notifications-list">
        <%= render partial: "recording_studio_notifications/digests/page", locals: { notifications: @notifications } %>
      </div>
    <% end %>

    <div class="pt-2">
      <%= render partial: "recording_studio_notifications/digests/next_page", locals: { page: @page, has_next_page: @has_next_page } %>
    </div>
  <% else %>
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.body do %>
        <p class="text-sm text-(--surface-muted-content-color)">No accessible events remain in this digest.</p>
      <% end %>
    <% end %>
  <% end %>
</div>