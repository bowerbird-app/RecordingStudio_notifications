<div id="<%= notification_group_dom_id(group) %>">
  <% if group.individual? %>
    <%= render FlatPack::List::Component.new(spacing: :dense, class: "space-y-0") do %>
      <%= render partial: "recording_studio_notifications/notifications/notification", locals: { notification: group.latest_notification } %>
    <% end %>
  <% else %>
    <% unread = group.unread_count.positive? %>
    <% title = content_tag(:span, class: "flex w-full items-center justify-between gap-4 #{'unread' if unread}") do %>
      <span class="min-w-0 space-y-0.5 text-left">
        <span class="block truncate"><%= group.notification_type_label %></span>
        <span class="block truncate text-xs font-normal text-(--surface-muted-content-color)"><%= group.period_label %></span>
      </span>
      <%= render FlatPack::Timestamp::Component.new(
        timestamp: group.latest_notification.created_at,
        shorten_timestamp: true,
        fallback_text: "",
        class_name: "shrink-0 text-sm font-normal text-(--surface-muted-content-color) whitespace-nowrap"
      ) %>
    <% end %>
    <%= render FlatPack::Accordion::Component.new(
      allow_multiple: true,
      class: "overflow-visible !border-0 !rounded-none bg-transparent [&>div]:!border-0 [&_[data-flat-pack--accordion-target=icon]]:hidden [&_[data-flat-pack--accordion-target=content][aria-expanded=true]]:!max-h-none [&_[data-flat-pack--accordion-target=trigger]]:min-h-[54px] [&_[data-flat-pack--accordion-target=trigger]]:items-start [&_[data-flat-pack--accordion-target=trigger]]:px-3 [&_[data-flat-pack--accordion-target=trigger]]:py-2 [&_[data-flat-pack--accordion-target=trigger]]:hover:bg-[var(--list-item-hover-background-color)] [&_[data-flat-pack--accordion-target=trigger]>span:first-child]:flex-1 [&_[data-flat-pack--accordion-target=trigger]>span:first-child>span:last-child]:flex-1 #{'[&_[data-flat-pack--accordion-target=trigger]]:bg-[var(--list-item-active-background-color)]' if unread}"
    ) do |accordion| %>
      <% accordion.item(
        id: group.id,
        title: title,
        left_slot: notification_group_leading_icon(group),
        open: index.zero?
      ) do %>
        <% initial_notifications = group.notifications.first(group_notifications_per_page) %>
        <%= render FlatPack::List::Component.new(spacing: :comfortable, divider: true) do %>
          <div id="<%= notification_group_items_dom_id(group) %>">
            <% initial_notifications.each do |notification| %>
              <%= render partial: "recording_studio_notifications/notifications/notification", locals: { notification: notification } %>
            <% end %>
            <%= render partial: "recording_studio_notifications/notifications/group_next_page", locals: {
              group: group,
              page: 1,
              has_next_page: group.notifications.size > initial_notifications.size
            } %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>