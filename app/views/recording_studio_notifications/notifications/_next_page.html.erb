<% next_page_params = request.query_parameters.merge(page: page + 1, format: :turbo_stream) %>

<%= turbo_frame_tag "notifications_next_page", src: (has_next_page ? notifications_path(next_page_params) : nil), loading: (has_next_page ? :lazy : nil) do %>
  <% if has_next_page %>
    <div class="py-3 text-center text-xs text-(--surface-muted-content-color)">Loading more notifications...</div>
  <% end %>
<% end %>
