<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <%= render FlatPack::PageNav::Component.new(
    anchor_url: main_app.root_path
  ) do |nav| %>
    <% nav.right do %>
      <%= link_to settings_path do %>
        <%= render FlatPack::Button::Component.new(
          icon: "cog",
          icon_only: true,
          style: :secondary,
          size: :md,
          aria: { label: "Settings" }
        ) %>
      <% end %>
    <% end %>
  <% end %>

  <%= render FlatPack::PageTitle::Component.new(
    title: "Notifications",
    variant: :h1
  ) %>

  <% if @notifications.any? %>
    <%= render FlatPack::List::Component.new(spacing: :comfortable, divider: true) do %>
      <% @notifications.each do |notification| %>
        <%= render FlatPack::List::Item.new(
          icon: notification_icon_for(notification),
          href: open_notification_path(notification),
          hover: true,
          active: notification.unread?,
          trailing: render(
            FlatPack::Timestamp::Component.new(
              timestamp: notification.created_at,
              shorten_timestamp: true,
              fallback_text: "",
              class_name: "text-sm text-(--surface-muted-content-color) whitespace-nowrap"
            )
          ),
          class: "mb-0"
        ) do %>
          <div class="space-y-0.5 text-left">
            <div class="truncate text-sm font-medium text-(--surface-content-color)"><%= notification.title %></div>
            <% if notification.body.present? %>
              <div class="line-clamp-2 text-xs text-(--surface-muted-content-color)"><%= notification.body %></div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.body do %>
        <p class="text-sm text-(--surface-muted-content-color)">No notifications yet.</p>
      <% end %>
    <% end %>
  <% end %>
</div>
