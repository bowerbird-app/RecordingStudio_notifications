<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Notifications",
    subtitle: "Recent in-app notifications for your Recording Studio workspace.",
    variant: :h1
  ) %>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap gap-2">
      <%= link_to notifications_path(scope: :all) do %>
        <%= render FlatPack::Button::Component.new(text: "All", style: @inbox_scope == "all" ? :primary : :secondary, size: :sm) %>
      <% end %>
      <%= link_to notifications_path(scope: :current_root) do %>
        <%= render FlatPack::Button::Component.new(text: "Current root", style: @inbox_scope == "current_root" ? :primary : :secondary, size: :sm) %>
      <% end %>
    </div>
    <%= link_to settings_path do %>
      <%= render FlatPack::Button::Component.new(text: "Settings", style: :secondary, size: :sm) %>
    <% end %>
  </div>

  <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
    <% card.body do %>
      <% if @notifications.any? %>
        <div class="flex flex-col gap-3">
          <% @notifications.each do |notification| %>
            <div class="rounded-lg border border-[var(--border-color)] p-4">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <p class="font-medium text-[var(--surface-content-color)]"><%= notification.title %></p>
                  <% if notification.body.present? %>
                    <p class="mt-1 text-sm text-[var(--surface-muted-content-color)]"><%= notification.body %></p>
                  <% end %>
                  <% if notification.rootless? %>
                    <p class="mt-2 text-xs text-[var(--surface-muted-content-color)]">Global</p>
                  <% end %>
                </div>
                <%= render FlatPack::Badge::Component.new(text: notification.read? ? "Read" : "Unread") %>
              </div>
              <div class="mt-4 flex flex-wrap gap-2">
                <%= link_to notification_path(notification) do %>
                  <%= render FlatPack::Button::Component.new(text: "Open", style: :secondary, size: :sm) %>
                <% end %>
                <% if notification.unread? %>
                  <%= button_to mark_read_notification_path(notification), method: :patch do %>
                    <%= render FlatPack::Button::Component.new(text: "Mark read", style: :ghost, size: :sm) %>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-[var(--surface-muted-content-color)]">No notifications yet.</p>
      <% end %>
    <% end %>
  <% end %>
</div>
