<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Notifications Demo",
    subtitle: "This dummy app is the browser-facing demo surface for Recording Studio notifications.",
    variant: :h1
  ) %>

  <div class="grid gap-6 lg:grid-cols-2">
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "What's working",
          subtitle: "Core notification capabilities already wired into the dummy app.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <ul class="space-y-3 text-sm leading-6">
          <li>Notification routes are mounted at <code>/notifications</code>.</li>
          <li>UUID-backed notification and delivery tables are included in the engine.</li>
          <li>The public API supports <code>notify</code>, <code>notify_each</code>, idempotency, root resolution, and URL safety.</li>
          <li>The dummy app exercises authentication, FlatPack layouts, and Recording Studio setup.</li>
        </ul>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Try it",
          subtitle: "Create in-app notifications from the Rails console.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <ol class="space-y-3 text-sm leading-6 list-decimal pl-5">
          <li>Open <code>bin/rails console</code>.</li>
          <li>Set <code>Current.actor = User.first</code>.</li>
          <li>Call <code>RecordingStudioNotifications.notify(notification_type: :workspace_digest, recipient: User.first, title: "Digest ready", url: "/")</code>.</li>
          <li>Visit <code>/notifications</code> to view the in-app notification.</li>
        </ol>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "FlatPack usage",
          subtitle: "This page uses FlatPack components for its primary UI structure.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <p class="text-sm leading-6 text-(--surface-content-color)">
          Use FlatPack cards, buttons, badges, inputs, and layout primitives as the default path for addon UI. Keep raw HTML for simple semantic content only.
        </p>
      <% end %>

      <% card.footer do %>
        <a href="https://github.com/bowerbird-app/flatpack"
           target="_blank"
           rel="noopener noreferrer"
           class="inline-flex">
          <%= render FlatPack::Button::Component.new(
            text: "View FlatPack documentation",
            style: :primary,
            size: :md
          ) %>
        </a>
      <% end %>
    <% end %>

    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "Install flow",
          subtitle: "What the host app generator path covers.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <ul class="space-y-3 text-sm leading-6">
          <li>Add the gem to your host app and run <code>bundle install</code>.</li>
          <li>Run <code>rails generate recording_studio_notifications:install</code> to mount the engine and add configuration.</li>
          <li>Run <code>rails generate recording_studio_notifications:migrations</code> to copy engine migrations into the host app.</li>
          <li>Rebuild Tailwind if needed with <code>bin/rails tailwindcss:build</code>.</li>
        </ul>
      <% end %>
    <% end %>
  </div>
</div>
